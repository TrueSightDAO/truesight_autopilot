.env
.venv
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
*.log
.pytest_cache/
.mypy_cache/

# Google service-account private keys — provisioned out-of-band, never
# committed. See config/google/README.md.
config/google/*.json

# Gmail OAuth tokens (per-account) — also out-of-band. See config/gmail/README.md.
config/gmail/*.json

# .env backups (created automatically by some flows) — never commit
.env.backup.*
.req-hash

# Telethon user-session (attention watchdog) — FULL account access, never commit.
*.session
*.session-journal
# Watchdog runtime state
data/attention_watchdog_state.json

# Runtime dirs — generated on the box, must NEVER be deleted by a deploy.
# deploy.sh runs `git clean -fd`; if these are not ignored it wipes Sophia's
# session memory + context mirrors. (Incident-adjacent, 2026-06-10.)
sessions/
context/
oracle/
worktrees/
# The encrypted credential vault (vault.key + vault.json.enc + vault_audit.json).
# `git clean -fd` respects .gitignore, so listing it here is what keeps a deploy
# from nuking the master key and every stored credential. It was NOT listed and
# a deploy wiped all 31 credentials on 2026-06-15 — do not remove this line.
vault/

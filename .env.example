# GitHub — fine-grained PAT with Contents:Read+Write + Pull requests:Read+Write
TRUESIGHT_DAO_AUTOPILOT=

# Gmail — paste full token.json contents (market_research/credentials/gmail/token.json)
GMAIL_TOKEN_JSON=

# LLM — DeepSeek only (dropped Kimi + Claude for cost)
# Either DEEPSEEK_API_KEY or DEEPSEEK_SDK works
DEEPSEEK_API_KEY=
DEEPSEEK_SDK=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Tavily — web search / page extraction for the chat agent (get a key at tavily.com)
TAVILY_API=

# Beta-deploy gate (Telegram /ship). OFF by default — even deployed, /ship does
# nothing until this is true. BETA_AUTO_MERGE=true skips the one-tap confirm (B6).
BETA_DEPLOY_GATE_ENABLED=false
BETA_AUTO_MERGE=false

# Edgar — dedicated automation identity (generate with truesight-dao-auth login)
EMAIL=autopilot@agroverse.shop
PUBLIC_KEY=
PRIVATE_KEY=

# AWS — multi-account support. Labels = DAO-member name (lowercased) so log
# lines identify whose account each signal came from. See app/aws_monitor.py
# docstring for the full convention.
#
# Multi-account form (preferred):
AWS_ACCOUNTS=nelanco,explorya
AWS_ACCESS_KEY_ID_NELANCO=
AWS_SECRET_ACCESS_KEY_NELANCO=
AWS_REGION_NELANCO=us-east-1
AWS_ACCESS_KEY_ID_EXPLORYA=
AWS_SECRET_ACCESS_KEY_EXPLORYA=
AWS_REGION_EXPLORYA=us-east-1
#
# Legacy single-account form (still works as fallback when AWS_ACCOUNTS is unset):
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# Bugsnag — autopilot self-reports its own crashes + ERROR-level logs to this
# Bugsnag project. The same project's email notifications then flow back into
# email_poller's bugsnag_error classifier, closing the self-improvement loop
# (autopilot crash -> Bugsnag -> email -> autopilot triages -> AI/proposed fix PR).
# Disabled silently when empty.
BUG_SNAG_API=
BUGSNAG_RELEASE_STAGE=production

# Bugsnag-project-name -> github-repo lookup for the inbound bugsnag_error
# handler. Project name is the bracketed prefix in the email subject
# ("[Krake Publisher] HTTPError ..." -> "Krake Publisher"). Unmapped
# projects log a warning and the handler returns None (no auto-PR).
# Add entries as you decide which projects autopilot can safely fix-PR for.
BUGSNAG_PROJECT_REPOS={"autopilot":"truesight_autopilot"}

# Service
PORT=8001
HOST=0.0.0.0
DRY_RUN=false
MAX_PR_PER_DAY=5
LOG_LEVEL=INFO

# Security (governor chat JWT)
JWT_SECRET=change-me-in-production

# Context sync
AGENTIC_CONTEXT_REPO=https://github.com/TrueSightDAO/agentic_ai_context.git
CONTEXT_REPOS_DIR=/opt/truesight_autopilot/context

# Google API credentials — autopilot Google Drive/Sheets/Docs/Apps-Script access.
# Default service-account JSON pointed at by GOOGLE_APPLICATION_CREDENTIALS;
# all SA files live in GOOGLE_CREDS_DIR. See config/google/README.md.
GOOGLE_APPLICATION_CREDENTIALS=/opt/truesight_autopilot/config/google/cypher_defense_gdrive_key.json
GOOGLE_CREDS_DIR=/opt/truesight_autopilot/config/google

# Gmail OAuth tokens — per-account, file-per-mailbox under GMAIL_TOKENS_DIR.
# Names: {account}_token.json (e.g. admin_token.json, gary_token.json).
# GMAIL_DEFAULT_ACCOUNT is what the agent uses when a tool call omits `account`.
# Legacy: GMAIL_TOKEN_JSON (inline JSON blob) is still read by email_poller and
# falls through to the "admin" account when admin_token.json is missing.
# See config/gmail/README.md.
GMAIL_TOKENS_DIR=/opt/truesight_autopilot/config/gmail
GMAIL_DEFAULT_ACCOUNT=admin
